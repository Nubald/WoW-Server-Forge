{
  "id": "azerothcore_cata",
  "display_name": "AzerothCore Cataclysm (4.3.4)",
  "short_name": "AC Cata",
  "expansion": "cata",
  "wow_version": "4.3.4",
  "repo": {
    "url": "https://github.com/azerothcore/azerothcore-wotlk.git",
    "branch": "cataclysm",
    "min_commit": null
  },
  "build": {
    "cmake_generator": "Visual Studio 17 2022",
    "cmake_arch": "x64",
    "default_options": {
      "TOOLS": "ON",
      "USE_COREPCH": "ON",
      "WITH_WARNINGS": "OFF"
    },
    "required_vs_version": "17",
    "supported_build_types": ["RelWithDebInfo", "Release", "Debug"]
  },
  "databases": [
    { "key": "auth",       "default_name": "acore_auth",       "sql_dir": "data/sql/base/db_auth",       "update_dir": "data/sql/updates/db_auth" },
    { "key": "characters", "default_name": "acore_characters",  "sql_dir": "data/sql/base/db_characters",  "update_dir": "data/sql/updates/db_characters" },
    { "key": "world",      "default_name": "acore_world",       "sql_dir": "data/sql/base/db_world",       "update_dir": "data/sql/updates/db_world" }
  ],
  "executables": {
    "authserver": "authserver.exe",
    "worldserver": "worldserver.exe"
  },
  "conf_templates": {
    "authserver": "authserver.conf.dist",
    "worldserver": "worldserver.conf.dist"
  },
  "compatible_modules": ["eluna"],
  "client_version": "4.3.4-15595",
  "notes": "AzerothCore Cataclysm branch — actively developed but less mature than the WotLK version.",
  "color_accent": "#E67E22"
}
