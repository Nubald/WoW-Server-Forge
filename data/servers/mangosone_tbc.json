{
  "id": "mangosone_tbc",
  "display_name": "MaNGOSOne TBC (2.4.3)",
  "short_name": "MaNGOS1 TBC",
  "expansion": "tbc",
  "wow_version": "2.4.3",
  "repo": {
    "url": "https://github.com/mangosone/server.git",
    "branch": "develop21",
    "min_commit": null
  },
  "build": {
    "cmake_generator": "Visual Studio 17 2022",
    "cmake_arch": "x64",
    "default_options": {
      "BUILD_TOOLS": "ON",
      "BUILD_PLAYERBOT": "OFF"
    },
    "required_vs_version": "17",
    "supported_build_types": ["RelWithDebInfo", "Release", "Debug"]
  },
  "databases": [
    { "key": "auth",       "default_name": "realmd1",    "sql_dir": "sql",  "update_dir": "sql/updates/realmd" },
    { "key": "characters", "default_name": "characters1", "sql_dir": "sql",  "update_dir": "sql/updates/characters" },
    { "key": "world",      "default_name": "mangos1",     "sql_dir": "sql",  "update_dir": "sql/updates/world" }
  ],
  "executables": {
    "authserver": "realmd.exe",
    "worldserver": "mangosd.exe"
  },
  "conf_templates": {
    "authserver": "realmd.conf.dist",
    "worldserver": "mangosd.conf.dist"
  },
  "compatible_modules": [],
  "client_version": "2.4.3-8606",
  "notes": "Original MaNGOS project for The Burning Crusade. Requires YTDB or similar world database.",
  "color_accent": "#9B59B6"
}
