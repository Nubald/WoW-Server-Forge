{
  "id": "mangosthree_cata",
  "display_name": "MaNGOSThree Cataclysm (4.3.4)",
  "short_name": "MaNGOS3 Cata",
  "expansion": "cata",
  "wow_version": "4.3.4",
  "repo": {
    "url": "https://github.com/mangosthree/server.git",
    "branch": "develop21",
    "min_commit": null
  },
  "build": {
    "cmake_generator": "Visual Studio 17 2022",
    "cmake_arch": "x64",
    "default_options": {
      "BUILD_TOOLS": "ON",
      "BUILD_PLAYERBOT": "OFF"
    },
    "required_vs_version": "17",
    "supported_build_types": ["RelWithDebInfo", "Release", "Debug"]
  },
  "databases": [
    { "key": "auth",       "default_name": "realmd3",    "sql_dir": "sql",  "update_dir": "sql/updates/realmd" },
    { "key": "characters", "default_name": "characters3", "sql_dir": "sql",  "update_dir": "sql/updates/characters" },
    { "key": "world",      "default_name": "mangos3",     "sql_dir": "sql",  "update_dir": "sql/updates/world" }
  ],
  "executables": {
    "authserver": "realmd.exe",
    "worldserver": "mangosd.exe"
  },
  "conf_templates": {
    "authserver": "realmd.conf.dist",
    "worldserver": "mangosd.conf.dist"
  },
  "compatible_modules": [],
  "client_version": "4.3.4-15595",
  "notes": "Original MaNGOS project for Cataclysm. Content coverage is less complete than earlier expansions.",
  "color_accent": "#E74C3C"
}
