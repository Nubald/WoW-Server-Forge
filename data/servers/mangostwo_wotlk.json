{
  "id": "mangostwo_wotlk",
  "display_name": "MaNGOSTwo WotLK (3.3.5a)",
  "short_name": "MaNGOS2 WotLK",
  "expansion": "wotlk",
  "wow_version": "3.3.5a",
  "repo": {
    "url": "https://github.com/mangostwo/server.git",
    "branch": "develop21",
    "min_commit": null
  },
  "build": {
    "cmake_generator": "Visual Studio 17 2022",
    "cmake_arch": "x64",
    "default_options": {
      "BUILD_TOOLS": "ON",
      "BUILD_PLAYERBOT": "OFF"
    },
    "required_vs_version": "17",
    "supported_build_types": ["RelWithDebInfo", "Release", "Debug"]
  },
  "databases": [
    { "key": "auth",       "default_name": "realmd2",    "sql_dir": "sql",  "update_dir": "sql/updates/realmd" },
    { "key": "characters", "default_name": "characters2", "sql_dir": "sql",  "update_dir": "sql/updates/characters" },
    { "key": "world",      "default_name": "mangos2",     "sql_dir": "sql",  "update_dir": "sql/updates/world" }
  ],
  "executables": {
    "authserver": "realmd.exe",
    "worldserver": "mangosd.exe"
  },
  "conf_templates": {
    "authserver": "realmd.conf.dist",
    "worldserver": "mangosd.conf.dist"
  },
  "compatible_modules": [],
  "client_version": "3.3.5a-12340",
  "notes": "Original MaNGOS project for Wrath of the Lich King. Alternative to TrinityCore/AzerothCore.",
  "color_accent": "#3498DB"
}
