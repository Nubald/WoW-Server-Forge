{
  "id": "oregoncore_tbc",
  "display_name": "OregonCore TBC (2.4.3)",
  "short_name": "OregonCore",
  "expansion": "tbc",
  "wow_version": "2.4.3",
  "repo": {
    "url": "https://github.com/OregonCore/OregonCore.git",
    "branch": "master",
    "min_commit": null
  },
  "build": {
    "cmake_generator": "Visual Studio 17 2022",
    "cmake_arch": "x64",
    "default_options": {
      "TOOLS": "ON",
      "USE_COREPCH": "ON",
      "WITH_WARNINGS": "OFF"
    },
    "required_vs_version": "17",
    "supported_build_types": ["RelWithDebInfo", "Release", "Debug"]
  },
  "databases": [
    { "key": "auth",       "default_name": "realmd",    "sql_dir": "sql/base",  "update_dir": "sql/updates/realmd" },
    { "key": "characters", "default_name": "characters", "sql_dir": "sql/base",  "update_dir": "sql/updates/characters" },
    { "key": "world",      "default_name": "oregon",     "sql_dir": "sql/base",  "update_dir": "sql/updates/world" }
  ],
  "executables": {
    "authserver": "realmd.exe",
    "worldserver": "oregon-core.exe"
  },
  "conf_templates": {
    "authserver": "realmd.conf.dist",
    "worldserver": "oregon-core.conf.dist"
  },
  "compatible_modules": [],
  "client_version": "2.4.3-8606",
  "notes": "OregonCore is a TBC emulator forked from early TrinityCore. Good TBC content coverage.",
  "color_accent": "#27AE60"
}
