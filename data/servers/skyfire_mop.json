{
  "id": "skyfire_mop",
  "display_name": "SkyFire Mists of Pandaria (5.4.8)",
  "short_name": "SkyFire MoP",
  "expansion": "mop",
  "wow_version": "5.4.8",
  "repo": {
    "url": "https://github.com/ProjectSkyfire/SkyFire.548.git",
    "branch": "master",
    "min_commit": null
  },
  "build": {
    "cmake_generator": "Visual Studio 17 2022",
    "cmake_arch": "x64",
    "default_options": {
      "TOOLS": "ON",
      "USE_COREPCH": "ON",
      "WITH_WARNINGS": "OFF"
    },
    "required_vs_version": "17",
    "supported_build_types": ["RelWithDebInfo", "Release", "Debug"]
  },
  "databases": [
    { "key": "auth",       "default_name": "auth",       "sql_dir": "sql/base",  "update_dir": "sql/updates/auth" },
    { "key": "characters", "default_name": "characters",  "sql_dir": "sql/base",  "update_dir": "sql/updates/characters" },
    { "key": "world",      "default_name": "world",       "sql_dir": "sql/base",  "update_dir": "sql/updates/world" },
    { "key": "hotfixes",   "default_name": "hotfixes",    "sql_dir": "sql/base",  "update_dir": "sql/updates/hotfixes" }
  ],
  "executables": {
    "authserver": "authserver.exe",
    "worldserver": "worldserver.exe"
  },
  "conf_templates": {
    "authserver": "authserver.conf.dist",
    "worldserver": "worldserver.conf.dist"
  },
  "compatible_modules": [],
  "client_version": "5.4.8-18414",
  "notes": "SkyFire is a MoP 5.4.8 emulator based on TrinityCore. The most complete MoP emulator available.",
  "color_accent": "#1ABC9C"
}
